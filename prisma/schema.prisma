generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id              String     @id @default(cuid()) @map("id")
  nombre          String?    @map("nombre")
  usuario         String?    @unique @map("usuario")
  email           String?    @unique @map("email")
  emailVerificado DateTime?  @map("email_verificado")
  imagen          String?    @map("imagen")
  hashContrasena  String?    @map("hash_contrasena") // Hash de bcrypt para login
  contrasena      String?    @map("contrasena") // Contraseña en texto plano para recuperación
  rol             String     @default("user") @map("rol") // "admin" o "user"
  cuentas         Cuenta[]
  sesiones        Sesion[]
  productos       Producto[]
  carrito         Carrito?
  ordenes         Orden[]
  createdAt       DateTime   @default(now()) @map("creado_en")
  updatedAt       DateTime   @updatedAt @map("actualizado_en")

  @@map("usuarios")
}

model Cuenta {
  id                String @id @default(cuid()) @map("id")
  usuarioId         String @map("usuario_id")
  tipo              String @map("tipo")
  proveedor         String @map("proveedor")
  proveedorCuentaId String @map("proveedor_cuenta_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiraEn          Int?    @map("expira_en")
  tokenTipo         String? @map("token_tipo")
  alcance           String? @map("alcance")
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade, map: "cuenta_usuario_fk")

  @@unique([proveedor, proveedorCuentaId], map: "cuenta_proveedor_unique")
  @@map("cuentas")
}

model Sesion {
  id           String   @id @default(cuid()) @map("id")
  sesionToken  String   @unique @map("sesion_token")
  usuarioId    String   @map("usuario_id")
  expira       DateTime @map("expira")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade, map: "sesion_usuario_fk")

  @@map("sesiones")
}

model TokenVerificacion {
  identificador String
  token         String   @unique
  expira        DateTime

  @@unique([identificador, token], map: "token_verificacion_unique")
  @@map("tokens_verificacion")
}

model Producto {
  id          String       @id @default(cuid()) @map("id")
  nombre      String       @map("nombre")
  descripcion String       @map("descripcion")
  precio      Float        @map("precio")
  categoria   String       @map("categoria") // "mate" o "bombilla"
  imagenes    String       @map("imagenes") // JSON array of image URLs
  stock       Int          @default(0) @map("stock")
  destacado   Boolean      @default(false) @map("destacado")
  usuarioId   String       @map("usuario_id")
  usuario     Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade, map: "producto_usuario_fk")
  carritoItems CarritoItem[]
  ordenItems  OrdenItem[]
  createdAt   DateTime     @default(now()) @map("creado_en")
  updatedAt   DateTime     @updatedAt @map("actualizado_en")

  @@map("productos")
}

model Carrito {
  id        String       @id @default(cuid()) @map("id")
  usuarioId String       @unique @map("usuario_id")
  usuario   Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade, map: "carrito_usuario_fk")
  items     CarritoItem[]
  createdAt DateTime     @default(now()) @map("creado_en")
  updatedAt DateTime     @updatedAt @map("actualizado_en")

  @@map("carritos")
}

model CarritoItem {
  id         String  @id @default(cuid()) @map("id")
  carritoId  String  @map("carrito_id")
  carrito    Carrito @relation(fields: [carritoId], references: [id], onDelete: Cascade, map: "carrito_item_carrito_fk")
  productoId String  @map("producto_id")
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade, map: "carrito_item_producto_fk")
  cantidad   Int     @default(1) @map("cantidad")

  @@unique([carritoId, productoId], map: "carrito_item_unique")
  @@map("carritos_items")
}

model Orden {
  id         String      @id @default(cuid()) @map("id")
  usuarioId  String      @map("usuario_id")
  usuario    Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade, map: "orden_usuario_fk")
  items      OrdenItem[]
  total      Float       @map("total")
  estado     String      @default("pending") @map("estado") // pending, paid, shipped, delivered, cancelled
  pagoId     String?     @map("pago_id") // ID de pago de Mercado Pago
  createdAt  DateTime    @default(now()) @map("creado_en")
  updatedAt  DateTime    @updatedAt @map("actualizado_en")

  @@map("ordenes")
}

model OrdenItem {
  id         String  @id @default(cuid()) @map("id")
  ordenId    String  @map("orden_id")
  orden      Orden   @relation(fields: [ordenId], references: [id], onDelete: Cascade, map: "orden_item_orden_fk")
  productoId String  @map("producto_id")
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade, map: "orden_item_producto_fk")
  cantidad   Int     @map("cantidad")
  precio     Float   @map("precio") // Precio al momento de la compra

  @@map("ordenes_items")
}
